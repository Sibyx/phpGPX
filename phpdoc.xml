<?xml version="1.0" encoding="UTF-8" ?>
<phpdocumentor
	configVersion="3"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="https://www.phpdoc.org/changes/3.0"
	xsi:noNamespaceSchemaLocation="https://docs.phpdoc.org/latest/phpdoc.xsd"
>
	<title>phpGPX API Documentation</title>

	<paths>
		<output>docs-output</output>
	</paths>

	<version number="2.0.0">
		<api>
			<source dsn=".">
				<path>src/phpGPX</path>
			</source>
			<output>api</output>
			<ignore hidden="true" symlinks="true">
				<path>vendor/**/*</path>
			</ignore>
			<default-package-name>phpGPX</default-package-name>
		</api>
	</version>
</phpdocumentor>